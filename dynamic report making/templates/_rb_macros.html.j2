{# templates/_rb_macros.html.j2 #}

{% macro render_block(b, ns) -%}
  {% set t = b.get("type", "") %}

  {% if t == "metrics_strip" %}
    <div class="kpiRow">
      {% for pair in (b.get("pairs", []) or []) %}
        <div class="kpi">
          <div class="kpiLabel">{{ pair[0] }}</div>
          <div class="kpiValue">{{ pair[1] }}</div>
        </div>
      {% endfor %}
    </div>

  {% elif t == "heading" %}
    {% set lvl = (b.get("level", 2) or 2) | int %}
    {% if lvl <= 2 %}
      <h3 class="h3">{{ b.get("text","") }}</h3>
    {% else %}
      <h4 class="h4">{{ b.get("text","") }}</h4>
    {% endif %}

  {% elif t == "paragraph" %}
    <p class="para">{{ b.get("text","") }}</p>

  {% elif t == "bullets" %}
    <ul class="bullets">
      {% for it in (b.get("items", []) or []) %}
        <li>{{ it }}</li>
      {% endfor %}
    </ul>

  {% elif t == "image" %}
    {# We do NOT want to use local PNG paths. We re-render charts in-browser using visual_id. #}
    {% set ns.fig = ns.fig + 1 %}
    {% set vid = b.get("visual_id") %}
    <figure class="figure">
      {% if vid %}
        <div class="chart" data-visual-id="{{ vid }}"></div>
      {% else %}
        {# If someday you add real photos (non-chart), only then this fallback is used #}
        {% if b.get("path") %}
          <img class="img" src="{{ b.get('path') }}" alt="{{ b.get('caption','') }}" />
        {% else %}
          <div class="chart chartMissing">
            <div class="chartMissingText">No visual_id / no image path</div>
          </div>
        {% endif %}
      {% endif %}
      {% if b.get("caption") %}
        <figcaption class="caption">Figure {{ ns.fig }}. {{ b.get("caption","") }}</figcaption>
      {% else %}
        <figcaption class="caption">Figure {{ ns.fig }}.</figcaption>
      {% endif %}
    </figure>

  {% elif t == "table" %}
    {% set ns.tbl = ns.tbl + 1 %}
    <div class="tableHeader">
      <div class="tableTag">Table {{ ns.tbl }}</div>
      {% if b.get("_truncated") %}
        <div class="tableNote">
          Showing first {{ (b.get("rows", []) or [])|length }} of {{ b.get("_total_rows", "") }} rows
        </div>
      {% endif %}
    </div>

    <div class="tableWrap">
      <table class="tbl" data-sortable="true">
        <thead>
          <tr>
            {% for h in (b.get("headers", []) or []) %}
              <th>{{ h }}</th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for r in (b.get("rows", []) or []) %}
            <tr>
              {% for cell in r %}
                <td>{{ cell }}</td>
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

  {% else %}
    <div class="small">[Unsupported block type: {{ t }}]</div>
  {% endif %}
{%- endmacro %}


{% macro render_section(s, ns) -%}
  {% if s.get("blocks") %}
    {% for b in (s.get("blocks", []) or []) %}
      {{ render_block(b, ns) }}
    {% endfor %}
  {% endif %}

  {% if s.get("themes") %}
    {% for t in (s.get("themes", []) or []) %}
      <div class="themeCard">
        <div class="themeTag">Theme</div>
        <div class="themeTitle">{{ t.get("title","Theme") }}</div>
        {% for b in (t.get("blocks", []) or []) %}
          {{ render_block(b, ns) }}
        {% endfor %}
      </div>
    {% endfor %}
  {% endif %}
{%- endmacro %}